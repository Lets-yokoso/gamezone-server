# Server
PORT=3000
NODE_ENV=production

# JWT - Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this

# Admin Credentials
# Generate hash with: node -e "console.log(require('bcryptjs').hashSync('your-password', 10))"
ADMIN_USERNAME=your-admin-username
ADMIN_PASSWORD_HASH=$2a$10$replace-with-bcrypt-hash

# Admin JWT secret (optional, defaults to JWT_SECRET + '_superadmin_v1')
# ADMIN_SECRET=your-admin-secret

# Database (optional - omit for local JSON file mode)
# MONGODB_URI=mongodb://localhost:27017/gamezone

# CORS - comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,https://yourdomain.com
